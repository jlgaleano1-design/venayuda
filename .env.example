NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key
NEXT_PUBLIC_SITE_URL=http://localhost:3000
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-for-server-only-scripts
EXCHANGE_RATE_API_URL=https://open.er-api.com/v6/latest/USD
USD_EXCHANGE_RATES_JSON={"MXN":0.055,"COP":0.00025}

# Email delivery. Sender is the recommended free SMTP provider for production.
EMAIL_PROVIDER=smtp
EMAIL_FROM="Vendonar <notificaciones@vendonar.org>"
APPROVAL_RECIPIENT_EMAIL=you@example.com
CAMPAIGN_REVIEW_SECRET=generate-a-long-random-secret
# Campaigns publish instantly only when an active admin checks the verified option.
EMAIL_WORKER_SECRET=generate-a-second-long-random-secret
CRON_SECRET=use-the-same-value-as-email-worker-secret-on-vercel

# Operational checks
TARGET_SITE_URL=http://localhost:3000
QA_EMAIL_DOMAIN=example.com
STRESS_CAMPAIGN_SLUG=

# SMTP provider credentials. Copy these values from your Sender SMTP settings.
SMTP_HOST=your-sender-smtp-host
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password

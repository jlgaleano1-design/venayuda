NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key
NEXT_PUBLIC_SITE_URL=http://localhost:3000
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-for-server-only-scripts

# Email delivery. Prefer Resend for the MVP.
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM="Vendonar <notificaciones@your-domain.com>"
APPROVAL_RECIPIENT_EMAIL=you@example.com
CAMPAIGN_REVIEW_SECRET=generate-a-long-random-secret
EMAIL_WORKER_SECRET=generate-a-second-long-random-secret
CRON_SECRET=use-the-same-value-as-email-worker-secret-on-vercel

# Operational checks
TARGET_SITE_URL=http://localhost:3000
STRESS_CAMPAIGN_SLUG=

# Optional SMTP fallback
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM="Vendonar <notificaciones@example.com>"
